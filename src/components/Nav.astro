---
import { sectionLinks } from '../consts'
---

<nav id="site-nav" aria-label="Primary" class="sticky top-0 z-50 bg-surface/70 backdrop-blur-md transition-transform duration-300">
    <div class="flex items-center justify-between py-4 px-6 md:px-10 font-mono text-sm">
        {/* Logo placeholder — links home; swap for real logo/SVG later */}
        <a href="#home" aria-label="Home" class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-accent/60 text-accent transition-colors hover:border-accent">
            SSG
        </a>
        <div class="flex items-center gap-6">
            {sectionLinks.map((link) => (
                <a href={link.href} class="hover:text-accent transition-colors">{link.label}</a>
            ))}
            <a href="/resume.pdf" download class="btn-accent">Resume ↓</a>
        </div>
    </div>
</nav>

<script>
    // Scroll-direction-aware: visible at top, hides on scroll-down, reveals on scroll-up.
    const nav = document.getElementById("site-nav");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (nav && !reduceMotion) {
        let lastY = window.scrollY;
        let ticking = false;

        const update = () => {
            const y = window.scrollY;
            if (y < 80 || y < lastY) {
                nav.classList.remove("-translate-y-full"); // near top or scrolling up
            } else {
                nav.classList.add("-translate-y-full"); // scrolling down
            }
            lastY = y;
            ticking = false;
        };

        // Coalesce scroll events to one update per animation frame.
        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    ticking = true;
                    requestAnimationFrame(update);
                }
            },
            { passive: true }
        );
    }
</script>