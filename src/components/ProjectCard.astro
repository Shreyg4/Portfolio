---
// Self-contained project card (portfolioPlan §4): gist readable inline, skills
// as per-project tags, optional award badge, a "View More" link to the detail
// page, and the live project link(s) when present.
import type { Project } from "../lib/projects";

interface Props {
    project: Project;
}

const { project } = Astro.props;
const { title, oneLiner, role, timeframe, stack, links, award, note } = project.data;
const hasExternal = links.live || links.repo || links.video;
---

<article class="flex flex-col rounded-lg bg-text/3 p-6 transition duration-200 hover:-translate-y-1 hover:bg-text/6">
    {
        award && (
            <p class="mb-3 w-fit rounded-full border border-accent/40 px-3 py-1 font-mono text-xs text-accent">
                {award.place} — {award.event}
            </p>
        )
    }

    <h3 class="text-xl font-bold">{title}</h3>
    <p class="mt-1 font-mono text-xs text-text/55">{role} · {timeframe}</p>
    <p class="mt-3 text-text/75">{oneLiner}</p>
    {note && <p class="mt-2 font-mono text-xs text-accent/80">↳ {note}</p>}

    <ul class="mt-4 flex flex-wrap gap-2">
        {
            stack.map((s) => (
                <li class="rounded bg-text/6 px-2 py-1 font-mono text-xs text-text/70">
                    {s}
                </li>
            ))
        }
    </ul>

    <div class="mt-6 flex flex-wrap items-center gap-5 text-sm">
        <a
            href={`/work/${project.id}`}
            class="font-medium text-accent underline-offset-4 hover:underline"
        >
            View More →
        </a>
        {
            hasExternal && (
                <span class="flex flex-wrap gap-4 text-text/70">
                    {links.live && (
                        <a href={links.live} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Live ↗
                        </a>
                    )}
                    {links.repo && (
                        <a href={links.repo} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Code ↗
                        </a>
                    )}
                    {links.video && (
                        <a href={links.video} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Demo ↗
                        </a>
                    )}
                </span>
            )
        }
    </div>
</article>
