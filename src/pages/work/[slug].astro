---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { slug: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
const { title, oneLiner, role, timeframe, status, stack, links, award } = project.data;
const { Content } = await render(project);
const hasExternal = links.live || links.repo || links.video;
---

<BaseLayout title={`${title} — Shreyas Sundar Ganesh`} description={oneLiner}>
    <article class="wrapper py-32">
        <a href="/#projects" class="font-mono text-sm text-accent underline-offset-4 hover:underline">
            ← Back to projects
        </a>

        {
            award && (
                <p class="mt-8 w-fit rounded-full border border-accent/40 px-3 py-1 font-mono text-xs text-accent">
                    {award.place} — {award.event}
                </p>
            )
        }

        <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
        <p class="mt-3 text-lg text-text/75">{oneLiner}</p>
        <p class="mt-2 font-mono text-xs text-text/55">{role} · {timeframe} · {status}</p>

        <ul class="mt-5 flex flex-wrap gap-2">
            {
                stack.map((s) => (
                    <li class="rounded bg-text/6 px-2 py-1 font-mono text-xs text-text/70">
                        {s}
                    </li>
                ))
            }
        </ul>

        {
            hasExternal && (
                <div class="mt-6 flex flex-wrap gap-5 text-sm text-text/70">
                    {links.live && (
                        <a href={links.live} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Live ↗
                        </a>
                    )}
                    {links.repo && (
                        <a href={links.repo} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Code ↗
                        </a>
                    )}
                    {links.video && (
                        <a href={links.video} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                            Demo ↗
                        </a>
                    )}
                </div>
            )
        }

        <div
            class="mt-12 max-w-2xl space-y-4 [&_h2]:mt-8 [&_h2]:font-mono [&_h2]:text-sm [&_h2]:text-accent [&_p]:leading-relaxed [&_p]:text-text/75"
        >
            <Content />
        </div>
    </article>
</BaseLayout>
